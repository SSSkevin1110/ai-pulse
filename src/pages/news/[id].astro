---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import newsData from '../../data/news-data.json';
import '../../styles/global.css';

export function getStaticPaths() {
  return newsData.map(article => ({
    params: { id: article.id },
    props: { article }
  }));
}

const { article } = Astro.props;

// Get related articles (same category)
const relatedArticles = newsData
  .filter(item => item.category === article.category && item.id !== article.id)
  .slice(0, 3);

// Get category label
function getCategoryLabel(category) {
  const labels = {
    'LLM': 'LLM',
    'Robotics': '机器人',
    'AutoDrive': '自动驾驶',
    'OpenClaw': 'OpenClaw',
    'Multimodal': '多模态',
    'AI Apps': 'AI应用'
  };
  return labels[category] || category;
}

// Get category color
function getCategoryColor(category) {
  const colors = {
    'LLM': '#E53935',
    'Robotics': '#FF6B6B',
    'AutoDrive': '#4ECDC4',
    'OpenClaw': '#E53935',
    'Multimodal': '#9B59B6',
    'AI Apps': '#F39C12'
  };
  return colors[category] || '#E53935';
}

// Format date
function formatDate(dateStr) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  });
}

// Estimate read time
function getReadTime(content) {
  const words = content?.split(/\s+/).length || 0;
  const minutes = Math.ceil(words / 200);
  return Math.max(1, minutes);
}
---

<Layout title={`${article.titleZh} | AI Pulse`} description={article.summaryZh}>
  <Header />
  
  <main class="pt-24 pb-16">
    <div class="container-custom">
      <!-- Back Button -->
      <a 
        href="/ai-pulse/" 
        class="inline-flex items-center gap-2 text-[var(--text-secondary)] hover:text-brand transition-colors mb-8"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        返回首页
      </a>

      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <article class="glass-card rounded-3xl overflow-hidden">
            <!-- Article Header -->
            <div class="p-6 md:p-10">
              <!-- Category & Meta -->
              <div class="flex items-center gap-3 mb-6">
                <span 
                  class="px-3 py-1 rounded-full text-xs font-semibold text-white"
                  style={`background-color: ${getCategoryColor(article.category)}`}
                >
                  {getCategoryLabel(article.category)}
                </span>
              </div>

              <!-- Title -->
              <h1 class="text-2xl md:text-4xl font-bold text-[var(--text-primary)] mb-4 leading-tight">
                {article.titleZh}
              </h1>

              <!-- English Title -->
              <p class="text-lg text-[var(--text-secondary)] mb-6 italic">
                {article.title}
              </p>

              <!-- Meta Info -->
              <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-secondary)] mb-8 pb-8 border-b border-[var(--border-primary)]">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-[var(--bg-secondary)] flex items-center justify-center">
                    <span class="text-xs font-bold">{article.source.charAt(0)}</span>
                  </div>
                  <span class="font-medium">{article.source}</span>
                </div>
                <span>·</span>
                <span>{formatDate(article.date)}</span>
                <span>·</span>
                <span class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                  </svg>
                  {getReadTime(article.content)} 分钟阅读
                </span>
              </div>

              <!-- Cover Image -->
              <div class="rounded-2xl overflow-hidden mb-8">
                <img 
                  src={article.image} 
                  alt={article.titleZh}
                  class="w-full h-auto object-cover"
                />
              </div>

              <!-- Summary -->
              <div class="bg-[var(--accent-light)] rounded-2xl p-6 mb-8">
                <div class="flex items-center gap-2 mb-3">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand">
                    <path d="M12 2H2v10h10V2z"></path>
                    <path d="M12 12H2v10h10V12z"></path>
                    <path d="M22 2h-10v10h10V2z"></path>
                    <path d="M22 12h-10v10h10V12z"></path>
                  </svg>
                  <span class="font-semibold text-[var(--text-primary)]">摘要</span>
                </div>
                <p class="text-[var(--text-secondary)] leading-relaxed">
                  {article.summaryZh}
                </p>
              </div>

              <!-- Content -->
              <div class="prose prose-lg max-w-none text-[var(--text-primary)]">
                {article.content.split('\n\n').map((paragraph) => (
                  <p class="mb-4 leading-relaxed text-[var(--text-secondary)]">
                    {paragraph}
                  </p>
                ))}
              </div>

              <!-- Source Link -->
              <div class="mt-10 pt-8 border-t border-[var(--border-primary)]">
                <a 
                  href={article.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--bg-secondary)] hover:bg-brand hover:text-white text-[var(--text-primary)] font-medium rounded-xl transition-all duration-200"
                >
                  <span>阅读原文</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" x2="21" y1="14" y2="3"></line>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          {/* Share Card */}
          <div class="glass-card rounded-2xl p-6">
            <h3 class="font-semibold text-[var(--text-primary)] mb-4">分享文章</h3>
            <div class="flex items-center gap-3">
              <button class="w-10 h-10 rounded-xl bg-[var(--bg-secondary)] flex items-center justify-center text-[var(--text-secondary)] hover:text-brand hover:bg-[var(--accent-light)] transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
                  <polyline points="16 6 12 2 8 6"></polyline>
                  <line x1="12" x2="12" y1="2" y2="15"></line>
                </svg>
              </button>
              <button class="w-10 h-10 rounded-xl bg-[var(--bg-secondary)] flex items-center justify-center text-[var(--text-secondary)] hover:text-brand hover:bg-[var(--accent-light)] transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                  <path d="M15 2H9a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1Z"></path>
                </svg>
              </button>
              <button class="w-10 h-10 rounded-xl bg-[var(--bg-secondary)] flex items-center justify-center text-[var(--text-secondary)] hover:text-brand hover:bg-[var(--accent-light)] transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3"></circle>
                  <circle cx="6" cy="12" r="3"></circle>
                  <circle cx="18" cy="19" r="3"></circle>
                  <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line>
                  <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line>
                </svg>
              </button>
            </div>
          </div>

          {/* Related Articles */}
          {relatedArticles.length > 0 && (
            <div class="glass-card rounded-2xl p-6">
              <h3 class="font-semibold text-[var(--text-primary)] mb-4">相关推荐</h3>
              <div class="space-y-4">
                {relatedArticles.map((related) => (
                  <a href={`/ai-pulse/news/${related.id}`} class="group block">
                    <div class="flex gap-3">
                      <div class="w-20 h-20 rounded-xl overflow-hidden flex-shrink-0">
                        <img 
                          src={related.image} 
                          alt={related.titleZh}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        />
                      </div>
                      <div class="flex-1 min-w-0">
                        <span 
                          class="inline-block px-2 py-0.5 rounded-full text-xs font-medium text-white mb-1"
                          style={`background-color: ${getCategoryColor(related.category)}`}
                        >
                          {getCategoryLabel(related.category)}
                        </span>
                        <h4 class="text-sm font-medium text-[var(--text-primary)] line-clamp-2 group-hover:text-brand transition-colors">
                          {related.titleZh}
                        </h4>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Category Info */}
          <div class="glass-card rounded-2xl p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">
                {article.category === 'LLM' && '🧠'}
                {article.category === 'Robotics' && '🤖'}
                {article.category === 'AutoDrive' && '🚗'}
                {article.category === 'OpenClaw' && '🦞'}
                {article.category === 'Multimodal' && '🎨'}
                {article.category === 'AI Apps' && '💡'}
              </span>
              <div>
                <h3 class="font-semibold text-[var(--text-primary)]">{getCategoryLabel(article.category)}</h3>
                <p class="text-xs text-[var(--text-secondary)]">
                  {newsData.filter(item => item.category === article.category).length} 篇文章
                </p>
              </div>
            </div>
            <a 
              href={`/ai-pulse/feed?tag=${article.category}`}
              class="w-full py-2.5 bg-[var(--bg-secondary)] hover:bg-brand hover:text-white text-[var(--text-primary)] text-sm font-medium rounded-xl transition-all duration-200 flex items-center justify-center gap-2"
            >
              查看更多相关文章
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
