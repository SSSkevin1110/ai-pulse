---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import newsData from '../../data/news.json';

export function getStaticPaths() {
  return newsData.news.map(item => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;

const categoryColors: Record<string, string> = {
  'LLM': 'from-red-500 to-red-600',
  'Robotics': 'from-orange-500 to-orange-600',
  'AutoDrive': 'from-blue-500 to-blue-600',
  'OpenClaw': 'from-purple-500 to-purple-600',
  'Multimodal': 'from-green-500 to-green-600',
  'AI Apps': 'from-yellow-500 to-yellow-600',
};

const categoryNamesZh: Record<string, string> = {
  'LLM': '大模型',
  'Robotics': '机器人',
  'AutoDrive': '自动驾驶',
  'OpenClaw': 'OpenClaw',
  'Multimodal': '多模态',
  'AI Apps': 'AI应用',
};

// Convert newlines to paragraphs
const contentParagraphs = item.content.split('\n\n');
---

<Layout title={`${item.titleZh} - AI Pulse`} description={item.summaryZh}>
  <Header />
  
  <main class="relative z-10 pt-24 pb-20">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back button -->
      <a href="/" class="inline-flex items-center text-gray-600 dark:text-gray-400 hover:text-primary transition-colors mb-8">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span data-en="Back to News" data-zh="返回资讯">返回资讯</span>
      </a>
      
      <!-- Header -->
      <header class="mb-8">
        <div class="flex items-center gap-4 mb-4">
          <span class={`px-3 py-1 rounded-full text-sm font-semibold text-white bg-gradient-to-r ${categoryColors[item.category]}`}>
            {categoryNamesZh[item.category]}
          </span>
          <span class="text-gray-500 dark:text-gray-400">{item.source}</span>
          <span class="text-gray-400">•</span>
          <span class="text-gray-500 dark:text-gray-400">{item.date}</span>
        </div>
        
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 leading-tight">
          {item.titleZh}
        </h1>
        
        <p class="text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
          {item.summaryZh}
        </p>
      </header>
      
      <!-- Featured Image -->
      <div class="relative rounded-2xl overflow-hidden mb-12 aspect-video">
        <img 
          src={item.image} 
          alt={item.titleZh}
          class="w-full h-full object-cover"
        />
      </div>
      
      <!-- Content -->
      <div class="prose prose-lg dark:prose-invert max-w-none">
        {contentParagraphs.map(paragraph => (
          <p class="mb-6 text-gray-700 dark:text-gray-300 leading-relaxed">
            {paragraph}
          </p>
        ))}
      </div>
      
      <!-- Source Link -->
      <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
        <a 
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 rounded-full bg-primary text-white font-medium hover:bg-primary-dark transition-colors"
        >
          <span data-en="Read Original Article" data-zh="阅读原文">阅读原文</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
      </div>
    </article>
  </main>
  
  <Footer />
</Layout>
