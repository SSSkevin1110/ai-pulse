---
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/70 dark:bg-black/70 border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center space-x-2">
        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center animate-glow">
          <span class="text-white font-bold text-lg">P</span>
        </div>
        <span class="text-xl font-bold bg-gradient-to-r from-primary to-primary-dark bg-clip-text text-transparent">
          AI Pulse
        </span>
      </div>
      
      <!-- Search -->
      <div class="hidden md:flex flex-1 max-w-md mx-8">
        <div class="relative w-full">
          <input 
            type="text" 
            id="search-input"
            placeholder="Search news..."
            class="w-full px-4 py-2 pl-10 rounded-full bg-glass-light dark:bg-glass-dark backdrop-blur-sm border border-gray-200 dark:border-gray-700 focus:border-primary focus:outline-none transition-colors"
            data-en-placeholder="Search news..."
            data-zh-placeholder="搜索新闻..."
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
      </div>
      
      <!-- Controls -->
      <div class="flex items-center space-x-4">
        <!-- Language Switch -->
        <button id="lang-toggle" class="p-2 rounded-lg bg-glass-light dark:bg-glass-dark backdrop-blur-sm border border-gray-200 dark:border-gray-700 hover:border-primary transition-colors">
          <span class="text-sm font-medium">EN/中</span>
        </button>
        
        <!-- Theme Switch -->
        <button id="theme-toggle" class="p-2 rounded-lg bg-glass-light dark:bg-glass-dark backdrop-blur-sm border border-gray-200 dark:border-gray-700 hover:border-primary transition-colors">
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
