const categoryColors: Record<string, string> = {
  'LLM': 'from-red-500 to-red-600',
  'Robotics': 'from-orange-500 to-orange-600',
  'AutoDrive': 'from-blue-500 to-blue-600',
  'OpenClaw': 'from-purple-500 to-purple-600',
  'Multimodal': 'from-green-500 to-green-600',
  'AI Apps': 'from-yellow-500 to-yellow-600',
};
---

<section class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-12">
      <span class="bg-gradient-to-r from-primary to-primary-dark bg-clip-text text-transparent">
        <span data-en="Latest News" data-zh="最新资讯">Latest News</span>
      </span>
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {newsItems.map((item) => (
        <article 
          class="group relative bg-glass-light dark:bg-glass-dark backdrop-blur-md rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl"
          data-category={item.category}
        >
          <!-- Glow effect -->
          <div class={`absolute inset-0 bg-gradient-to-br ${categoryColors[item.category]} opacity-0 group-hover:opacity-5 transition-opacity duration-500`}></div>
          
          <!-- Image -->
          <div class="relative h-48 overflow-hidden">
            <img 
              src={item.image} 
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute top-4 left-4">
              <span class={`px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r ${categoryColors[item.category]}`}>
                {item.category}
              </span>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-6">
            <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400 mb-3">
              <span>{item.source}</span>
              <span>{item.date}</span>
            </div>
            
            <h3 class="text-lg font-bold mb-2 group-hover:text-primary transition-colors" data-en={item.title} data-zh={item.titleZh}>
              {item.title}
            </h3>
            
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-4" data-en={item.summary} data-zh={item.summaryZh}>
              {item.summary}
            </p>
            
            <a 
              href={item.url}
              class="inline-flex items-center text-primary font-semibold hover:underline"
            >
              <span data-en="Read more" data-zh="阅读更多">Read more</span>
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Load more -->
    <div class="text-center mt-12">
      <button class="px-8 py-3 rounded-full bg-primary text-white font-semibold hover:bg-primary-dark transition-colors shadow-lg hover:shadow-primary/50">
        <span data-en="Load More" data-zh="加载更多">Load More</span>
      </button>
    </div>
  </div>
</section>
