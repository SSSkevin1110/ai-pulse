---
import newsData from '../data/news.json';

const { news } = newsData;
const initialNews = news.slice(0, 12);

const categoryColors: Record<string, string> = {
  'LLM': 'from-red-500 to-red-600',
  'Robotics': 'from-orange-500 to-orange-600',
  'AutoDrive': 'from-blue-500 to-blue-600',
  'OpenClaw': 'from-purple-500 to-purple-600',
  'Multimodal': 'from-green-500 to-green-600',
  'AI Apps': 'from-yellow-500 to-yellow-600',
};

const categoryNamesZh: Record<string, string> = {
  'LLM': '大模型',
  'Robotics': '机器人',
  'AutoDrive': '自动驾驶',
  'OpenClaw': 'OpenClaw',
  'Multimodal': '多模态',
  'AI Apps': 'AI应用',
};
---

<section class="py-20 px-4 sm:px-6 lg:px-8" id="news">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center justify-between mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold">
        <span class="bg-gradient-to-r from-primary to-primary-dark bg-clip-text text-transparent">
          <span data-en="Latest News" data-zh="最新资讯">Latest News</span>
        </span>
      </h2>
      <span class="text-sm text-gray-500 dark:text-gray-400">
        <span data-en="Showing" data-zh="显示">Showing</span> <span id="result-count">{initialNews.length}</span> <span data-en="articles" data-zh="篇文章">articles</span>
      </span>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="news-grid">
      {initialNews.map((item) => (
        <article 
          class="group relative bg-white dark:bg-gray-800 rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-300 hover:shadow-xl"
          data-category={item.category}
        >
          <!-- Image -->
          <a href={`/news/${item.id}`} class="block relative h-48 overflow-hidden">
            <img 
              src={item.image} 
              alt={item.title}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute top-4 left-4">
              <span class={`px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r ${categoryColors[item.category]}`}>
                {categoryNamesZh[item.category]}
              </span>
            </div>
          </a>
          
          <!-- Content -->
          <div class="p-6">
            <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400 mb-3">
              <span>{item.source}</span>
              <span>{item.date}</span>
            </div>
            
            <a href={`/news/${item.id}`}>
              <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors line-clamp-2">
                {item.titleZh}
              </h3>
            </a>
            
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-4">
              {item.summaryZh}
            </p>
            
            <a 
              href={`/news/${item.id}`}
              class="inline-flex items-center text-primary font-medium hover:underline"
            >
              <span data-en="Read more" data-zh="阅读更多">阅读更多</span>
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
    
    <!-- Load more -->
    <div class="text-center mt-12">
      <button id="load-more" class="px-8 py-3 rounded-full bg-primary text-white font-medium hover:bg-primary-dark transition-colors shadow-lg">
        <span data-en="Load More" data-zh="加载更多">加载更多</span>
      </button>
    </div>
  </div>
</section>

<script>
  // Load more functionality
  const loadMoreBtn = document.getElementById('load-more');
  let currentCount = 12;
  const allNews = {JSON.stringify(news)};
  
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', () => {
      const newsGrid = document.getElementById('news-grid');
      const nextBatch = allNews.slice(currentCount, currentCount + 6);
      
      if (nextBatch.length === 0) {
        loadMoreBtn.style.display = 'none';
        return;
      }
      
      nextBatch.forEach(item => {
        const article = document.createElement('article');
        article.className = 'group relative bg-white dark:bg-gray-800 rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-primary transition-all duration-300 hover:shadow-xl';
        article.setAttribute('data-category', item.category);
        
        const categoryColors = {
          'LLM': 'from-red-500 to-red-600',
          'Robotics': 'from-orange-500 to-orange-600',
          'AutoDrive': 'from-blue-500 to-blue-600',
          'OpenClaw': 'from-purple-500 to-purple-600',
          'Multimodal': 'from-green-500 to-green-600',
          'AI Apps': 'from-yellow-500 to-yellow-600',
        };
        
        const categoryNamesZh = {
          'LLM': '大模型',
          'Robotics': '机器人',
          'AutoDrive': '自动驾驶',
          'OpenClaw': 'OpenClaw',
          'Multimodal': '多模态',
          'AI Apps': 'AI应用',
        };
        
        article.innerHTML = `
          <a href="/news/${item.id}" class="block relative h-48 overflow-hidden">
            <img 
              src="${item.image}" 
              alt="${item.title}"
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r ${categoryColors[item.category]}">
                ${categoryNamesZh[item.category]}
              </span>
            </div>
          </a>
          <div class="p-6">
            <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400 mb-3">
              <span>${item.source}</span>
              <span>${item.date}</span>
            </div>
            <a href="/news/${item.id}">
              <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors line-clamp-2">
                ${item.titleZh}
              </h3>
            </a>
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-4">
              ${item.summaryZh}
            </p>
            <a href="/news/${item.id}" class="inline-flex items-center text-primary font-medium hover:underline">
              <span>阅读更多</span>
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        `;
        
        newsGrid.appendChild(article);
      });
      
      currentCount += 6;
      
      if (currentCount >= allNews.length) {
        loadMoreBtn.style.display = 'none';
      }
      
      // Update count
      const countElement = document.getElementById('result-count');
      if (countElement) {
        countElement.textContent = currentCount;
      }
    });
  }
</script>
