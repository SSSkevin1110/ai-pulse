---
import newsData from '../data/news.json';

// Calculate real counts
const counts = newsData.news.reduce((acc, item) => {
  acc[item.category] = (acc[item.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const tags = [
  { name: 'LLM', nameZh: '大模型', color: 'bg-red-500', count: counts['LLM'] || 0 },
  { name: 'Robotics', nameZh: '机器人', color: 'bg-orange-500', count: counts['Robotics'] || 0 },
  { name: 'AutoDrive', nameZh: '自动驾驶', color: 'bg-blue-500', count: counts['AutoDrive'] || 0 },
  { name: 'OpenClaw', nameZh: 'OpenClaw', color: 'bg-purple-500', count: counts['OpenClaw'] || 0 },
  { name: 'Multimodal', nameZh: '多模态', color: 'bg-green-500', count: counts['Multimodal'] || 0 },
  { name: 'AI Apps', nameZh: 'AI应用', color: 'bg-yellow-500', count: counts['AI Apps'] || 0 },
];

const totalCount = newsData.news.length;
---

<section class="py-16 px-4 sm:px-6 lg:px-8 border-y border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
        按主题探索
      </h2>
      <p class="text-gray-500 dark:text-gray-400">
        点击分类筛选感兴趣的资讯
      </p>
    </div>
    
    <div class="flex flex-wrap justify-center gap-3">
      <!-- All button -->
      <button 
        class="group relative px-5 py-2.5 rounded-full bg-primary text-white font-medium shadow-lg shadow-primary/30 transition-all duration-300 hover:scale-105 hover:shadow-xl"
        data-tag="all"
      >
        <span class="flex items-center space-x-2">
          <span>全部</span>
          <span class="text-xs px-2 py-0.5 rounded-full bg-white/20">
            {totalCount}
          </span>
        </span>
      </button>
      
      {tags.map((tag) => (
        <button 
          class="group relative px-5 py-2.5 rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-medium transition-all duration-300 hover:scale-105 hover:border-primary hover:text-primary dark:hover:text-primary"
          data-tag={tag.name}
        >
          <span class="flex items-center space-x-2">
            <span class={`w-2 h-2 rounded-full ${tag.color}`}></span>
            <span>{tag.nameZh}</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
              {tag.count}
            </span>
          </span>
        </button>
      ))}
    </div>
  </div>
</section>
