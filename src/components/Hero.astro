---
import newsData from '../data/news.json';

const totalArticles = newsData.news.length;
const categories = ['LLM', 'Robotics', 'AutoDrive', 'OpenClaw', 'Multimodal', 'AI Apps'];
---

<section class="relative min-h-[70vh] flex items-center justify-center pt-16 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10"></div>
  
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold mb-4 tracking-tight">
      <span class="text-gray-900 dark:text-white">AI</span>
      <span class="text-primary">Pulse</span>
    </h1>
    <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">
      AI 领域最新资讯聚合平台
    </p>
    
    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8 mt-12">
      <div class="text-center">
        <div class="text-2xl font-semibold text-primary">{totalArticles}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">篇文章</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-semibold text-primary">{categories.length}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">个分类</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-semibold text-primary">每日</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">更新</div>
      </div>
    </div>
  </div>
</section>
