---
const currentYear = new Date().getFullYear();

const footerLinks = {
  product: [
    { label: '首页', href: '/ai-pulse/' },
    { label: '资讯流', href: '/ai-pulse/feed' },
    { label: '标签云', href: '/ai-pulse/tags' },
  ],
  resources: [
    { label: '关于我们', href: '#' },
    { label: '使用指南', href: '#' },
    { label: 'API 文档', href: '#' },
  ],
  legal: [
    { label: '隐私政策', href: '#' },
    { label: '用户协议', href: '#' },
    { label: '免责声明', href: '#' },
  ],
};

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>`
  },
  {
    label: 'Twitter',
    href: 'https://twitter.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>`
  },
  {
    label: 'RSS',
    href: '#',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>`
  },
];
---

<footer class="mt-20 border-t border-[var(--border-primary)]">
  <div class="container-custom py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/ai-pulse/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand to-brand-dark flex items-center justify-center">
            <span class="text-white font-bold text-sm">AI</span>
          </div>
          <span class="text-xl font-bold gradient-text">Pulse</span>
        </a>
        <p class="text-[var(--text-secondary)] text-sm mb-6 max-w-sm leading-relaxed">
          AI Pulse 是一个专注于 AI 领域的资讯聚合平台，致力于为用户提供最新、最全的人工智能行业动态。
        </p>
        <!-- Social Links -->
        <div class="flex items-center gap-3">
          {socialLinks.map((social) => (
            <a 
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-xl bg-[var(--bg-secondary)] flex items-center justify-center text-[var(--text-secondary)] hover:text-brand hover:bg-[var(--accent-light)] transition-all duration-200"
              aria-label={social.label}
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold text-[var(--text-primary)] mb-4">产品</h4>
        <ul class="space-y-3">
          {footerLinks.product.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-brand transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-[var(--text-primary)] mb-4">资源</h4>
        <ul class="space-y-3">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-brand transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-[var(--text-primary)] mb-4">法律</h4>
        <ul class="space-y-3">
          {footerLinks.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[var(--text-secondary)] hover:text-brand transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-[var(--border-primary)] flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-[var(--text-tertiary)]">
        © {currentYear} AI Pulse. All rights reserved.
      </p>
      <p class="text-sm text-[var(--text-tertiary)]">
        Made with ❤️ for AI enthusiasts
      </p>
    </div>
  </div>
</footer>

<!-- Back to Top Button -->
<button 
  id="backToTop"
  class="fixed bottom-8 right-8 w-12 h-12 rounded-full glass-card flex items-center justify-center text-[var(--text-secondary)] hover:text-brand hover:scale-110 transition-all duration-300 opacity-0 pointer-events-none z-40"
  aria-label="返回顶部"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="m18 15-6-6-6 6"></path>
  </svg>
</button>

<script>
  // Back to top functionality
  const backToTop = document.getElementById('backToTop');
  
  function toggleBackToTop() {
    if (window.scrollY > 500) {
      backToTop?.classList.remove('opacity-0', 'pointer-events-none');
      backToTop?.classList.add('opacity-100', 'pointer-events-auto');
    } else {
      backToTop?.classList.add('opacity-0', 'pointer-events-none');
      backToTop?.classList.remove('opacity-100', 'pointer-events-auto');
    }
  }

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  window.addEventListener('scroll', toggleBackToTop, { passive: true });
  toggleBackToTop();
</script>
